@inherits LayoutComponentBase
@inject NavigationManager NavManager

@code{
    private string currentPath => NavManager.ToBaseRelativePath(NavManager.Uri);
}

<div class="page">

    @if (currentPath.ToString().Contains("home"))
    {
        <div class="sidebar">
            <NavMenu />
        </div>
    }

    @if (NavManager.ToBaseRelativePath(NavManager.Uri) != "login")
    {
        <footer class="app-footer">...</footer>
    }

    <main>
        @* <div class="top-row px-4">
            <a href="https://learn.microsoft.com/aspnet/core/" target="_blank">About</a>
        </div> *@

        <article class="content px-4">
            @Body
        </article>

        <footer class="app-footer">
            <div class="container-fluid">
                <div class="row align-items-center">
                    <!-- Left: Copyright & Sync -->
                    <div class="col-md-4 text-start">
                        <p class="mb-0">&copy; 2013 - @DateTime.Now.Year Deuda</p>
                        <small class="text-muted">
                            <i class="bi bi-arrow-repeat @(isSyncing ? "spin" : "")"></i> 
                            Last Synced: @lastSynced.ToString("HH:mm:ss")
                        </small>
                    </div>

                    <!-- Center: Social Icons -->
                    <div class="col-md-4 text-center">
                        <a href="#" class="social-icon"><i class="bi bi-linkedin"></i></a>
                        <a href="#" class="social-icon"><i class="bi bi-twitter-x"></i></a>
                        <a href="#" class="social-icon"><i class="bi bi-github"></i></a>
                    </div>

                    <!-- Right: App Version -->
                    <div class="col-md-4 text-end">
                        <span class="badge rounded-pill bg-light text-dark border">v1.2.0-stable</span>
                    </div>
                </div>
            </div>
        </footer>
    </main>
</div>
